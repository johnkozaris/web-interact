{
  "name": "web-interact-daemon",
  "version": "0.2.0",
  "private": true,
  "description": "Node.js daemon for web-interact: QuickJS sandbox, Patchright browser control, CDP element discovery",
  "author": {
    "name": "John Kozaris",
    "email": "ioanniskozaris@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnkozaris/web-interact.git",
    "directory": "daemon"
  },
  "homepage": "https://github.com/johnkozaris/web-interact",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/daemon.ts --bundle --platform=node --format=esm --outfile=dist/daemon.bundle.mjs --external:patchright --external:quickjs-emscripten --external:@jitl/*",
    "bundle:sandbox-client": "tsx scripts/bundle-sandbox-client.ts",
    "dev": "tsx src/daemon.ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\""
  },
  "dependencies": {
    "patchright": "1.59.1",
    "patchright-core": "1.59.1",
    "quickjs-emscripten": "0.32.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "devtools-protocol": "^0.0.1604597",
    "esbuild": "^0.27.4",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2"
  }
}
